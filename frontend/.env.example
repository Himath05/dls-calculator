# Frontend Environment Variables

# ============================================
# FOR NETLIFY DEPLOYMENT (with Netlify Functions)
# ============================================
# You don't need to set REACT_APP_API_URL
# The app automatically uses /api which routes to Netlify Functions

# ============================================
# FOR LOCAL DEVELOPMENT
# ============================================
# Option 1: Test with local backend (backend/server.js)
REACT_APP_API_URL=http://localhost:5001/api

# Option 2: Test with Netlify Functions locally
# REACT_APP_API_URL=http://localhost:8888/api
# Run: netlify dev

# ============================================
# FOR SEPARATE BACKEND DEPLOYMENT
# ============================================
# If you deploy backend separately (not using Netlify Functions)
# Uncomment and set to your backend URL:
# REACT_APP_API_URL=https://your-backend.onrender.com/api
